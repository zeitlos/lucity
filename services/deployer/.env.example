# Deployer service configuration
PORT=9003
LOG_LEVEL=info
LOG_COLOR=true


# ArgoCD connection (insecure mode — HTTP, not HTTPS)
ARGOCD_ADDR=http://localhost:8443
ARGOCD_TOKEN=
ARGOCD_INSECURE=false

# Soft-serve HTTP URL (local access, e.g. via port-forward)
SOFTSERVE_HTTP_ADDR=http://lucity-infra-soft-serve.lucity-system.svc.cluster.local:23232

# Soft-serve cluster-internal URL for ArgoCD to clone GitOps repos.
# Only needed in local dev where SOFTSERVE_HTTP_ADDR is a port-forward.
# Falls back to SOFTSERVE_HTTP_ADDR if unset.
SOFTSERVE_CLUSTER_HTTP_ADDR=

# Soft-serve access token (for registering repos in ArgoCD)
SOFTSERVE_TOKEN=

# Packager gRPC address (for suspension via GitOps values)
PACKAGER_ADDR=localhost:9002

# Custom domain TLS provisioning
GATEWAY_NAME=lucity-gateway
GATEWAY_NAMESPACE=lucity-system
CLUSTER_ISSUER=letsencrypt-http01

# Internal JWT — ES256 keys for gRPC service-to-service auth (required)
# Generate with: make generate-internal-keys
# INTERNAL_JWT_PUBLIC_KEY_PATH=../../internal-jwt-public.pem
# INTERNAL_JWT_PRIVATE_KEY_PATH=../../internal-jwt-private.pem
