# Packager - GitOps repo management (gRPC :9002)
PORT=9002
LOG_LEVEL=info

# Auth
JWT_SECRET=change-me-in-production

# Soft-serve config
SOFTSERVE_SSH_ADDR=localhost:23231
SOFTSERVE_HTTP_ADDR=http://localhost:23232
SOFTSERVE_SSH_KEY_PATH=/path/to/admin-key
# HTTP access token for git clone/push. Create with:
#   ssh -i <key> -o IdentitiesOnly=yes -p 23231 localhost token create 'packager'
SOFTSERVE_TOKEN=
