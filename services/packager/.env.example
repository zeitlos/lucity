# Packager - GitOps repo management (gRPC :9002)
PORT=9002
LOG_LEVEL=info

# Auth
JWT_SECRET=change-me-in-production

# Git provider: "softserve" or "github"
GIT_PROVIDER=softserve

# Soft-serve config (when GIT_PROVIDER=softserve)
SOFTSERVE_SSH_ADDR=localhost:23231
SOFTSERVE_HTTP_ADDR=http://localhost:23232
SOFTSERVE_SSH_KEY_PATH=/path/to/admin-key
SOFTSERVE_TOKEN=
