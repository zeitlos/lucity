# Cashier service configuration
PORT=9005
WEBHOOK_PORT=9006
LOG_LEVEL=info
LOG_COLOR=true

# Deployer gRPC address
DEPLOYER_ADDR=localhost:9003

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_HOBBY_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ECO_CPU_PRICE_ID=price_...
STRIPE_ECO_MEM_PRICE_ID=price_...
STRIPE_ECO_DISK_PRICE_ID=price_...
STRIPE_PROD_CPU_PRICE_ID=price_...
STRIPE_PROD_MEM_PRICE_ID=price_...
STRIPE_PROD_DISK_PRICE_ID=price_...

# Billing Meter event names (create Billing Meters in Stripe Dashboard)
STRIPE_ECO_CPU_METER_EVENT=eco_cpu_usage
STRIPE_ECO_MEM_METER_EVENT=eco_memory_usage
STRIPE_ECO_DISK_METER_EVENT=eco_disk_usage
STRIPE_PROD_CPU_METER_EVENT=prod_cpu_usage
STRIPE_PROD_MEM_METER_EVENT=prod_memory_usage
STRIPE_PROD_DISK_METER_EVENT=prod_disk_usage

# Metering (optional — omit SIGNOZ_CLICKHOUSE_DSN to disable)
METERING_INTERVAL=1h
SIGNOZ_CLICKHOUSE_DSN=clickhouse://default:@chi-signoz-clickhouse-cluster-0-0-0.signoz:9000/signoz_metrics
