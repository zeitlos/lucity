LOG_COLOR=true

# Zot registry credentials (optional for local dev without auth).
# REGISTRY_USERNAME=builder
# REGISTRY_PASSWORD=

# Local Zot runs without TLS.
REGISTRY_INSECURE=true

# Required: container image for build Job pods.
BUILD_IMAGE=ghcr.io/zeitlos/lucity/builder:<tag>

# Build namespace (default: lucity-builds).
# BUILD_NAMESPACE=lucity-builds

# Kubernetes context for local dev (omit when running in-cluster).
# KUBE_CONTEXT=lucity-prod

# Registry URL (default: localhost:5000).
# REGISTRY_URL=lucity-infra-zot.lucity-system.svc.cluster.local:5000
# REGISTRY_AUTH_SECRET=lucity-registry-auth

# BuildKit address (default: tcp://lucity-buildkit:1234).
# BUILDKIT_ADDR=tcp://lucity-buildkit:1234

# Internal JWT — ES256 public key for verifying gRPC auth tokens (optional)
# Generate with: make generate-internal-keys
# INTERNAL_JWT_PUBLIC_KEY_PATH=../../internal-jwt-public.pem
# REQUIRE_INTERNAL_JWT=false
