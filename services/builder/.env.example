LOG_COLOR=true

# Zot registry credentials (optional for local dev without auth).
# REGISTRY_USERNAME=builder
# REGISTRY_PASSWORD=

# Local Zot runs without TLS.
REGISTRY_INSECURE=true

# Kubernetes build engine (for building via K8s Jobs against the production cluster).
# BUILD_ENGINE=kubernetes
# BUILD_IMAGE=ghcr.io/zeitlos/lucity/builder:<tag>
# BUILD_NAMESPACE=lucity-system
# KUBE_CONTEXT=lucity-prod
# REGISTRY_URL=lucity-infra-zot.lucity-system.svc.cluster.local:5000
# REGISTRY_AUTH_SECRET=lucity-registry-auth
# BUILDKIT_ADDR=tcp://lucity-buildkit:1234
