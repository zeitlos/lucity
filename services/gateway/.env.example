# Gateway - GraphQL API (HTTP :8080)
PORT=8080
LOG_LEVEL=info

# GitHub App (required — register at GitHub > Settings > Developer settings > GitHub Apps)
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=dev-secret

# Auth
JWT_SECRET=change-me-in-production
DASHBOARD_URL=http://localhost:5173
CALLBACK_URL=http://localhost:8080/auth/github/callback

# Backend services
BUILDER_ADDR=localhost:9001
PACKAGER_ADDR=localhost:9002
DEPLOYER_ADDR=localhost:9003

# Registry
REGISTRY_URL=localhost:5000
# Cluster-internal registry address for image refs in values.yaml (defaults to REGISTRY_URL)
# REGISTRY_IMAGE_PREFIX=lucity-infra-zot.lucity-system.svc.cluster.local:5000
