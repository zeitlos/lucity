# Gateway - GraphQL API (HTTP :8080)
PORT=8080
LOG_LEVEL=info

# GitHub App (required — register at GitHub > Settings > Developer settings > GitHub Apps)
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=dev-secret

# Auth
JWT_SECRET=change-me-in-production
DASHBOARD_URL=http://localhost:5173
CALLBACK_URL=http://localhost:8080/auth/github/callback
