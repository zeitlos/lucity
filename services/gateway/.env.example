# Gateway - GraphQL API (HTTP :8080)
PORT=8080
LOG_LEVEL=info
LOG_COLOR=true

# OIDC (Logto) — uses PKCE, no client secret needed
OIDC_ISSUER_URL=http://localhost:3001/oidc
OIDC_CLIENT_ID=
OIDC_CALLBACK_URL=http://localhost:8080/auth/callback

# Dashboard
DASHBOARD_URL=http://localhost:5173

# Session secret — used to sign HMAC session JWTs (required)
SESSION_SECRET=change-me-in-production

# Test auth (optional — overrides SESSION_SECRET for test tokens)
# AUTH_TEST_SECRET=change-me-in-production

# Logto Management API (M2M app credentials)
LOGTO_ENDPOINT=http://localhost:3001
LOGTO_M2M_APP_ID=
LOGTO_M2M_APP_SECRET=

# Backend services
BUILDER_ADDR=localhost:9001
PACKAGER_ADDR=localhost:9002
DEPLOYER_ADDR=localhost:9003
CASHIER_ADDR=localhost:9005

# GitHub App (for installation tokens + OAuth)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=
GITHUB_APP_SLUG=lucity-platform
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=http://localhost:8080/auth/github/callback

# Registry — push address (via port-forward)
REGISTRY_URL=localhost:5000
# Cluster-internal registry address for image refs in Helm values.
# For minikube: use Zot's fixed ClusterIP (Docker on minikube can't resolve cluster DNS).
# For production: use the cluster-internal service DNS name.
REGISTRY_IMAGE_PREFIX=10.96.100.50:5000

# Domains
WORKLOAD_DOMAIN=lucity.local
DOMAIN_TARGET=
IP_ADDRESS=

# Internal JWT — ES256 private key for signing gRPC auth tokens (optional)
# Generate with: make generate-internal-keys
# INTERNAL_JWT_PRIVATE_KEY_PATH=../../internal-jwt-private.pem
