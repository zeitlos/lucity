# Sensitive values for production deployment.
# Copy to secrets.yaml and fill in actual values.
# secrets.yaml is gitignored — never commit it.

secrets:
  GITHUB_WEBHOOK_SECRET: ""    # from GitHub App settings
  ARGOCD_TOKEN: ""             # make argocd-token
  SOFTSERVE_TOKEN: ""          # make softserve-token
  GITHUB_CLIENT_SECRET: ""     # from GitHub App settings → Client secrets
  REGISTRY_PASSWORD: ""        # openssl rand -hex 16
  REGISTRY_HTPASSWD: ""        # htpasswd -bBn builder "<REGISTRY_PASSWORD value>"
  STRIPE_SECRET_KEY: ""        # from Stripe Dashboard → Developers → API keys
  STRIPE_WEBHOOK_SECRET: ""    # from Stripe Dashboard → Developers → Webhooks → signing secret
  LOGTO_OIDC_CLIENT_ID: ""     # from Logto admin → Applications → "Lucity Gateway" → App ID
  LOGTO_M2M_APP_ID: ""         # from Logto admin → Applications → M2M app → App ID
  LOGTO_M2M_APP_SECRET: ""     # from Logto admin → Applications → M2M app → App Secret

# GitHub App private key (PEM format)
githubPrivateKey: |
  -----BEGIN RSA PRIVATE KEY-----
  ...
  -----END RSA PRIVATE KEY-----

# Soft-serve admin SSH key
softserveKey: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  ...
  -----END OPENSSH PRIVATE KEY-----

# Rybbit Analytics
rybbit:
  secrets:
    clickhousePassword: ""   # openssl rand -hex 16
    betterAuthSecret: ""     # openssl rand -hex 32

# Rauthy Identity Provider (kept for fallback, can be removed after Logto cutover)
rauthy:
  secrets:
    adminPassword: ""       # openssl rand -base64 24
    raftSecret: ""           # cat /dev/urandom | tr -dc 'a-zA-Z0-9' | head -c48
    apiSecret: ""            # cat /dev/urandom | tr -dc 'a-zA-Z0-9' | head -c48
    encryptionKey: ""        # echo "$(openssl rand -hex 4)/$(openssl rand -base64 32)"
    encryptionKeyId: ""      # hex part before / from encryptionKey

# Logto Identity Provider
logto:
  secrets:
    m2mAppId: ""             # same as LOGTO_M2M_APP_ID above
    m2mAppSecret: ""         # same as LOGTO_M2M_APP_SECRET above
