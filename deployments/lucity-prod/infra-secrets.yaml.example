# Infrastructure secrets for production deployment.
# Copy to infra-secrets.yaml and fill in actual values.
# infra-secrets.yaml is gitignored — never commit it.

# Zot OCI Registry
zot:
  configFiles:
    htpasswd: ""             # htpasswd -bBn builder "$(openssl rand -hex 16)"

# Soft-serve Git Server
softServe:
  initialAdminKey: ""        # cat ~/.ssh/lucity-admin-prod.pub

# Rybbit Analytics
rybbit:
  secrets:
    clickhousePassword: ""   # openssl rand -hex 16
    betterAuthSecret: ""     # openssl rand -hex 32

# Rauthy Identity Provider (kept for fallback, can be removed after Logto cutover)
rauthy:
  secrets:
    adminPassword: ""       # openssl rand -base64 24
    raftSecret: ""           # cat /dev/urandom | tr -dc 'a-zA-Z0-9' | head -c48
    apiSecret: ""            # cat /dev/urandom | tr -dc 'a-zA-Z0-9' | head -c48
    encryptionKey: ""        # echo "$(openssl rand -hex 4)/$(openssl rand -base64 32)"
    encryptionKeyId: ""      # hex part before / from encryptionKey

# Logto Identity Provider
logto:
  secrets:
    m2mAppId: ""             # from Logto admin → Applications → M2M app → App ID
    m2mAppSecret: ""         # from Logto admin → Applications → M2M app → App Secret
